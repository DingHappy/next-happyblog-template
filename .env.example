# ==============================================
# Local development environment
# ==============================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For production/server Docker deployment, start from:
#   cp .env.production.example .env
# ==============================================

# Public site URLs
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public template defaults
NEXT_PUBLIC_SITE_NAME="Next Blog Template"
NEXT_PUBLIC_SITE_TITLE="Next Blog Template - Write and publish with ease"
NEXT_PUBLIC_SITE_DESCRIPTION="A full-stack personal blog template."
NEXT_PUBLIC_SITE_LOGO_EMOJI="✨"
NEXT_PUBLIC_AUTHOR_NAME="Template Author"
NEXT_PUBLIC_AUTHOR_BIO="Use private config to personalize this template."
NEXT_PUBLIC_AUTHOR_AVATAR_EMOJI="👨‍💻"
NEXT_PUBLIC_AUTHOR_TAGLINE="Technology & Life"
NEXT_PUBLIC_SOCIAL_EMAIL=
NEXT_PUBLIC_SOCIAL_GITHUB=
NEXT_PUBLIC_SOCIAL_TWITTER=
NEXT_PUBLIC_SOCIAL_LINKEDIN=

# Application port
APP_PORT=3000

# Allowed origins in development, comma-separated
ALLOWED_DEV_ORIGINS=localhost

# ==============================================
# Database
# ==============================================
# Host-machine tools such as npm run dev and npx prisma use localhost.
# Docker app containers use postgres:5432; see .env.production.example.
DB_HOST=localhost
DB_PORT=5432
DB_USER=blog
DB_PASSWORD=your_secure_password_here
DB_NAME=blog_db
DATABASE_URL=postgresql://blog:your_secure_password_here@localhost:5432/blog_db?schema=public&connect_timeout=30&pool_timeout=30

# ==============================================
# Admin
# ==============================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_local_password
# Optional: use this instead of ADMIN_PASSWORD if you want to store only a hash.
ADMIN_PASSWORD_HASH=
ADMIN_EMAIL=admin@example.com
ADMIN_DISPLAY_NAME=管理员

# ==============================================
# Optional email notifications
# ==============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ==============================================
# App secrets
# ==============================================
# Generate production-grade secrets with:
#   openssl rand -hex 32
NEXTAUTH_SECRET=change_this_local_nextauth_secret
SCHEDULED_PUBLISH_SECRET=change_this_local_scheduled_publish_secret
CRON_SECRET=change_this_local_cron_secret

# Comment moderation overrides. Comma-separated, optional.
COMMENT_SPAM_KEYWORDS=
COMMENT_SPAM_EMAIL_DOMAINS=
COMMENT_BLOCKED_AUTHORS=

# Knowledge sync/export paths
KNOWLEDGE_BASE_PATH=/absolute/path/to/your/knowledge/docs
EXPORT_KNOWLEDGE_PATH=/absolute/path/to/export/docs

# Docker/Nginx ports
HTTP_PORT=80
HTTPS_PORT=443

# ==============================================
# Safety
# ==============================================
# 1. Do not commit real .env files.
# 2. Use .env.production.example as the server starting point.
# 3. Keep database passwords, admin passwords, SMTP credentials, and cron secrets private.
