# ==============================================
# 博客系统环境变量配置
# 复制此文件为 .env 并修改实际值
# ==============================================

# ==============================================
# 基础配置
# ==============================================

# 站点公开访问地址（必填）
NEXT_PUBLIC_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# 模板公开信息（可在私有生产仓库覆盖）
NEXT_PUBLIC_SITE_NAME="Next Blog Template"
NEXT_PUBLIC_SITE_TITLE="Next Blog Template - Write and publish with ease"
NEXT_PUBLIC_SITE_DESCRIPTION="A full-stack personal blog template."
NEXT_PUBLIC_SITE_LOGO_EMOJI="✨"
NEXT_PUBLIC_AUTHOR_NAME="Template Author"
NEXT_PUBLIC_AUTHOR_BIO="Use private config to personalize this template."
NEXT_PUBLIC_AUTHOR_AVATAR_EMOJI="👨‍💻"
NEXT_PUBLIC_AUTHOR_TAGLINE="Technology & Life"
NEXT_PUBLIC_SOCIAL_EMAIL=
NEXT_PUBLIC_SOCIAL_GITHUB=
NEXT_PUBLIC_SOCIAL_TWITTER=
NEXT_PUBLIC_SOCIAL_LINKEDIN=

# 应用监听端口
APP_PORT=3000

# 开发环境允许的来源，多个用逗号分隔
ALLOWED_DEV_ORIGINS=localhost

# ==============================================
# 数据库配置
# ==============================================

# PostgreSQL 连接信息
DB_HOST=postgres
DB_PORT=5432
DB_USER=blog
DB_PASSWORD=your_secure_password_here
DB_NAME=blog_db

# 完整数据库连接 URL（Prisma 使用）
DATABASE_URL=postgresql://blog:your_secure_password_here@postgres:5432/blog_db?schema=public&connect_timeout=30&pool_timeout=30

# ==============================================
# 管理员配置
# ==============================================

# 管理员密码（至少 8 位，建议使用强密码）
ADMIN_PASSWORD=your_admin_password_here

# 管理员邮箱（接收评论通知）
ADMIN_EMAIL=admin@example.com

# ==============================================
# 邮件服务配置（可选，用于评论通知）
# ==============================================

# SMTP 服务器地址
SMTP_HOST=smtp.example.com

# SMTP 端口（通常 587/465/25）
SMTP_PORT=587

# SMTP 用户名
SMTP_USER=noreply@example.com

# SMTP 密码
SMTP_PASSWORD=your_smtp_password

# 发件人地址
SMTP_FROM="博客通知 <noreply@example.com>"

# ==============================================
# Next.js 配置（可选）
# ==============================================

# NextAuth 密钥（生产环境必须设置）
# 使用 `openssl rand -hex 32` 生成
NEXTAUTH_SECRET=your_nextauth_secret_here

# 定时发布接口密钥
SCHEDULED_PUBLISH_SECRET=your_scheduled_publish_secret_here

# 自动备份接口密钥
CRON_SECRET=your_cron_secret_here

# 知识库同步/导出路径。公开模板只保留示例，生产环境在私有仓库或服务器 env 中配置。
KNOWLEDGE_BASE_PATH=/absolute/path/to/your/knowledge/docs
EXPORT_KNOWLEDGE_PATH=/absolute/path/to/export/docs

# ==============================================
# Docker 相关配置（可选）
# ==============================================

# Nginx HTTP/HTTPS 端口
HTTP_PORT=80
HTTPS_PORT=443

# ==============================================
# 安全提示
# ==============================================
# 1. 生产环境请务必修改所有默认密码
# 2. 定期备份数据库和上传文件
# 3. 启用 HTTPS 后请配置 SSL 证书
# 4. 不要将 .env 文件提交到版本控制
