# Production environment
# Copy this file to .env on the server. Keep the real .env private.

NEXT_PUBLIC_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com

NEXT_PUBLIC_SITE_NAME="Next Blog Template"
NEXT_PUBLIC_SITE_TITLE="Next Blog Template - Write and publish with ease"
NEXT_PUBLIC_SITE_DESCRIPTION="A full-stack personal blog template."
NEXT_PUBLIC_SITE_LOGO_EMOJI="✨"
NEXT_PUBLIC_AUTHOR_NAME="Template Author"
NEXT_PUBLIC_AUTHOR_BIO="Use private config to personalize this template."
NEXT_PUBLIC_AUTHOR_AVATAR_EMOJI="👨‍💻"
NEXT_PUBLIC_AUTHOR_TAGLINE="Technology & Life"
NEXT_PUBLIC_SOCIAL_EMAIL=
NEXT_PUBLIC_SOCIAL_GITHUB=
NEXT_PUBLIC_SOCIAL_TWITTER=
NEXT_PUBLIC_SOCIAL_LINKEDIN=

APP_PORT=3000
ALLOWED_DEV_ORIGINS=

# Docker services talk to PostgreSQL through the compose service name.
DB_HOST=postgres
DB_PORT=5432
DB_USER=blog
DB_PASSWORD=replace_with_a_strong_database_password
DB_NAME=blog_db
DATABASE_URL=postgresql://blog:replace_with_a_strong_database_password@postgres:5432/blog_db?schema=public&connect_timeout=30&pool_timeout=30

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_admin_password
ADMIN_PASSWORD_HASH=
ADMIN_EMAIL=admin@example.com
ADMIN_DISPLAY_NAME=管理员

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Generate secrets with: openssl rand -hex 32
NEXTAUTH_SECRET=replace_with_nextauth_secret
SCHEDULED_PUBLISH_SECRET=replace_with_scheduled_publish_secret
CRON_SECRET=replace_with_cron_secret

KNOWLEDGE_BASE_PATH=/absolute/path/to/your/knowledge/docs
EXPORT_KNOWLEDGE_PATH=/absolute/path/to/export/docs

HTTP_PORT=80
HTTPS_PORT=443
